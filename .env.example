# ─────────────────────────────────────────
# SUPABASE (shared by mobile + web)
# ─────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # web/admin ONLY, never in mobile

# ─────────────────────────────────────────
# MOBILE (Expo) — prefix with EXPO_PUBLIC_
# ─────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────
# WEB (Next.js) — prefix with NEXT_PUBLIC_ for client-side
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY is used server-side only (no NEXT_PUBLIC_ prefix)

# ─────────────────────────────────────────
# OPTIONAL SERVICES
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=